---
import BaseLayout from "../ui/layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found" noIndex={true} enablePageTransitions enableSound>
  <section class="py-24 text-center">
    <p class="text-6xl font-bold text-(--color-text-muted) mb-4">404</p>
    <h1 class="text-2xl font-bold tracking-tight mb-2">Page Not Found</h1>
    <p class="text-(--color-text-muted) mb-8">
      Sorry, the page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex gap-4 justify-center">
      <a
        href="/"
        class="inline-flex items-center px-5 py-2.5 rounded-lg bg-(--color-accent) text-white font-medium no-underline hover:bg-(--color-accent-hover) transition-colors"
      >
        Go Home
      </a>
      <a
        href="/projects"
        class="inline-flex items-center px-5 py-2.5 rounded-lg border border-(--color-border) text-(--color-text) font-medium no-underline hover:bg-gray-100 transition-colors"
      >
        View Projects
      </a>
    </div>
  </section>
</BaseLayout>
