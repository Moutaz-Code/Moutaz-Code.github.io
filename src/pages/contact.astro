---
import BaseLayout from "../ui/layouts/BaseLayout.astro";
import PageHeader from "../ui/components/primitives/PageHeader.astro";
import SignatureInit from "../ui/components/signature/SignatureInit.astro";
import ButtonLink from "../ui/components/primitives/ButtonLink.astro";
import Card from "../ui/components/primitives/Card.astro";
import { siteConfig } from "../app/siteConfig";

const email = siteConfig.socialLinks.email?.replace("mailto:", "") ?? "";

function displayLink(url: string) {
  return url.replace(/^mailto:/, "").replace(/^https?:\/\//, "").replace(/\/$/, "");
}

const channels = [
  siteConfig.socialLinks.github
    ? { label: "GitHub", url: siteConfig.socialLinks.github, display: displayLink(siteConfig.socialLinks.github), external: true }
    : null,
  siteConfig.socialLinks.linkedin
    ? { label: "LinkedIn", url: siteConfig.socialLinks.linkedin, display: displayLink(siteConfig.socialLinks.linkedin), external: true }
    : null,
  siteConfig.socialLinks.itch
    ? { label: "itch.io", url: siteConfig.socialLinks.itch, display: displayLink(siteConfig.socialLinks.itch), external: true }
    : null,
  siteConfig.socialLinks.shadertoy
    ? { label: "Shadertoy", url: siteConfig.socialLinks.shadertoy, display: displayLink(siteConfig.socialLinks.shadertoy), external: true }
    : null,
].filter(Boolean);
---

<BaseLayout
  title="Contact"
  description="Get in touch — I'd love to hear from you."
  enableSmoothScroll
  enableAmbient
  enableCursor
  enablePageTransitions
  enableSound
>
  <section class="py-8">
    <PageHeader
      title="Contact"
      subtitle="Have a question, project idea, or just want to say hi? Reach out through any of the channels below."
      enableSignature
    />

    {siteConfig.socialLinks.email && (
      <div class="mb-8">
        <ButtonLink href={siteConfig.socialLinks.email} variant="primary" magnetic sfx="click">
          Email Me
        </ButtonLink>
      </div>
    )}

    <div class="grid gap-4 md:grid-cols-2 mb-12">
      {siteConfig.socialLinks.email && (
        <Card class="p-5">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-sm font-medium text-(--color-text)">Email</p>
              <a
                href={siteConfig.socialLinks.email}
                class="mt-2 block break-all text-sm text-(--color-text-muted) no-underline hover:text-(--color-text) transition-colors"
              >
                {email}
              </a>
            </div>
            <button
              type="button"
              id="copy-email-btn"
              data-email={email}
              class="shrink-0 text-xs px-2 py-1 rounded border border-(--color-border) text-(--color-text-muted) hover:border-(--color-accent) hover:text-(--color-accent) transition-colors cursor-pointer"
            >
              Copy
            </button>
          </div>
        </Card>
      )}

      {
        channels.map((channel) => (
          <Card href={channel.url} target="_blank" rel="noreferrer" class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-sm font-medium text-(--color-text)">{channel.label}</p>
                <p class="mt-2 break-all text-sm text-(--color-text-muted)">{channel.display}</p>
              </div>
              <span aria-hidden="true" class="shrink-0 text-xs text-(--color-text-muted)">↗</span>
            </div>
          </Card>
        ))
      }
    </div>
  </section>
  <SignatureInit />
</BaseLayout>

<script>
  const btn = document.getElementById("copy-email-btn");
  if (btn) {
    btn.addEventListener("click", async () => {
      const email = btn.getAttribute("data-email") ?? "";
      try {
        await navigator.clipboard.writeText(email);
        const original = btn.textContent;
        btn.textContent = "Copied!";
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch {
        // Fallback: select text in a temporary input
        const input = document.createElement("input");
        input.value = email;
        document.body.appendChild(input);
        input.select();
        document.execCommand("copy");
        document.body.removeChild(input);
        const original = btn.textContent;
        btn.textContent = "Copied!";
        setTimeout(() => { btn.textContent = original; }, 1500);
      }
    });
  }
</script>
