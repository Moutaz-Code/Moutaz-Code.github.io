---
import BaseLayout from "../ui/layouts/BaseLayout.astro";
import SignatureUnderline from "../ui/components/signature/SignatureUnderline.astro";
import SignatureInit from "../ui/components/signature/SignatureInit.astro";
import ButtonLink from "../ui/components/primitives/ButtonLink.astro";
import { siteConfig } from "../app/siteConfig";

const email = siteConfig.socialLinks.email?.replace("mailto:", "") ?? "";
---

<BaseLayout
  title="Contact"
  description="Get in touch — I'd love to hear from you."
  enableSmoothScroll
  enableAmbient
  enableCursor
  enablePageTransitions
  enableSound
>
  <section class="py-8">
    <h1 class="text-3xl font-bold tracking-tight mb-1">Contact</h1>
    <SignatureUnderline variant="header" class="mb-2" />
    <p class="text-(--color-text-muted) mb-8">
      Have a question, project idea, or just want to say hi? Reach out through
      any of the channels below.
    </p>

    <!-- Primary CTA -->
    {siteConfig.socialLinks.email && (
      <div class="mb-10">
        <ButtonLink href={siteConfig.socialLinks.email} variant="primary" magnetic sfx="click">
          Email Me
        </ButtonLink>
      </div>
    )}

    {(siteConfig.socialLinks.itch || siteConfig.socialLinks.shadertoy) && (
      <div class="mb-10 flex flex-wrap gap-3">
        {siteConfig.socialLinks.itch && (
          <ButtonLink
            href={siteConfig.socialLinks.itch}
            variant="secondary"
            external
            magnetic
            sfx="click"
          >
            itch.io
          </ButtonLink>
        )}
        {siteConfig.socialLinks.shadertoy && (
          <ButtonLink
            href={siteConfig.socialLinks.shadertoy}
            variant="secondary"
            external
            magnetic
            sfx="click"
          >
            Shadertoy
          </ButtonLink>
        )}
      </div>
    )}

    <!-- Contact channels -->
    <div class="space-y-4 mb-12">
      {siteConfig.socialLinks.email && (
        <div class="flex items-center gap-3">
          <a
            href={siteConfig.socialLinks.email}
            class="flex items-center gap-3 no-underline text-(--color-text) hover:text-(--color-accent) transition-colors"
          >
            <span class="text-sm font-medium">Email</span>
            <span class="text-sm text-(--color-text-muted)">{email}</span>
          </a>
          <button
            type="button"
            id="copy-email-btn"
            data-email={email}
            class="text-xs px-2 py-1 rounded border border-(--color-border) text-(--color-text-muted) hover:border-(--color-accent) hover:text-(--color-accent) transition-colors cursor-pointer"
          >
            Copy
          </button>
        </div>
      )}
      {siteConfig.socialLinks.github && (
        <a
          href={siteConfig.socialLinks.github}
          target="_blank"
          rel="noreferrer"
          class="flex items-center gap-3 no-underline text-(--color-text) hover:text-(--color-accent) transition-colors"
        >
          <span class="text-sm font-medium">GitHub</span>
          <span class="text-sm text-(--color-text-muted)">{siteConfig.socialLinks.github}</span>
          <span class="text-xs text-(--color-text-muted)">&#x2197;</span>
        </a>
      )}
      {siteConfig.socialLinks.linkedin && (
        <a
          href={siteConfig.socialLinks.linkedin}
          target="_blank"
          rel="noreferrer"
          class="flex items-center gap-3 no-underline text-(--color-text) hover:text-(--color-accent) transition-colors"
        >
          <span class="text-sm font-medium">LinkedIn</span>
          <span class="text-sm text-(--color-text-muted)">{siteConfig.socialLinks.linkedin}</span>
          <span class="text-xs text-(--color-text-muted)">&#x2197;</span>
        </a>
      )}
      {siteConfig.socialLinks.itch && (
        <a
          href={siteConfig.socialLinks.itch}
          target="_blank"
          rel="noreferrer"
          class="flex items-center gap-3 no-underline text-(--color-text) hover:text-(--color-accent) transition-colors"
        >
          <span class="text-sm font-medium">itch.io</span>
          <span class="text-sm text-(--color-text-muted)">{siteConfig.socialLinks.itch}</span>
          <span class="text-xs text-(--color-text-muted)">&#x2197;</span>
        </a>
      )}
      {siteConfig.socialLinks.shadertoy && (
        <a
          href={siteConfig.socialLinks.shadertoy}
          target="_blank"
          rel="noreferrer"
          class="flex items-center gap-3 no-underline text-(--color-text) hover:text-(--color-accent) transition-colors"
        >
          <span class="text-sm font-medium">Shadertoy</span>
          <span class="text-sm text-(--color-text-muted)">{siteConfig.socialLinks.shadertoy}</span>
          <span class="text-xs text-(--color-text-muted)">&#x2197;</span>
        </a>
      )}
    </div>
  </section>
  <SignatureInit />
</BaseLayout>

<script>
  const btn = document.getElementById("copy-email-btn");
  if (btn) {
    btn.addEventListener("click", async () => {
      const email = btn.getAttribute("data-email") ?? "";
      try {
        await navigator.clipboard.writeText(email);
        const original = btn.textContent;
        btn.textContent = "Copied!";
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch {
        // Fallback: select text in a temporary input
        const input = document.createElement("input");
        input.value = email;
        document.body.appendChild(input);
        input.select();
        document.execCommand("copy");
        document.body.removeChild(input);
        const original = btn.textContent;
        btn.textContent = "Copied!";
        setTimeout(() => { btn.textContent = original; }, 1500);
      }
    });
  }
</script>
