---
import { contentSource } from "../app/content";
import BaseLayout from "../ui/layouts/BaseLayout.astro";
import HeroSignature from "../ui/components/home/HeroSignature.astro";
import HeroSignatureInit from "../ui/components/home/HeroSignatureInit.astro";
import FeaturedProjects from "../ui/components/home/FeaturedProjects.astro";
import SkillsStrip from "../ui/components/home/SkillsStrip.astro";
import ExperienceSection from "../ui/components/home/ExperienceSection.astro";
import LatestPosts from "../ui/components/home/LatestPosts.astro";
import ContactCTA from "../ui/components/home/ContactCTA.astro";
import MagneticInit from "../ui/components/motion/MagneticInit.astro";
import SectionDivider from "../ui/components/signature/SectionDivider.astro";
import DividerInit from "../ui/components/signature/DividerInit.astro";

const featuredProjects = await contentSource.listProjects({ featuredOnly: true, limit: 3 });
const latestPosts = await contentSource.listPosts({ limit: 2 });
---

<BaseLayout enableMotion enableSmoothScroll enableAmbient enableCursor>
  <HeroSignature />
  <SectionDivider variant="wave" class="my-4" />
  <FeaturedProjects projects={featuredProjects} />
  <SectionDivider variant="circuit" class="my-4" />
  <SkillsStrip />
  <SectionDivider variant="harmonic" class="my-4" />
  <ExperienceSection />
  <LatestPosts posts={latestPosts} />
  <ContactCTA />
  <HeroSignatureInit />
  <MagneticInit />
  <DividerInit />
</BaseLayout>
