---
import { contentSource } from "../../app/content";
import BaseLayout from "../../ui/layouts/BaseLayout.astro";
import PageHeader from "../../ui/components/primitives/PageHeader.astro";
import PostCard from "../../ui/components/content/PostCard.astro";
import BlogFilterBar from "../../ui/components/content/BlogFilterBar.astro";
import SignatureInit from "../../ui/components/signature/SignatureInit.astro";
import SectionDivider from "../../ui/components/signature/SectionDivider.astro";
import DividerInit from "../../ui/components/signature/DividerInit.astro";

const allPosts = await contentSource.listPosts();
const allTags = await contentSource.listTags();
const blogTags = allTags
  .filter((t) => t.countPosts > 0)
  .map((t) => ({ slug: t.slug, label: t.label }));
---

<BaseLayout
  title="Blog"
  description="Posts about software engineering, architecture, and creative coding."
  enableMotion
  enableSmoothScroll
  enableAmbient
  ambientVariant="c"
  enableCursor
>
  <section class="py-8">
    <PageHeader
      title="Blog"
      subtitle="Posts about software engineering, architecture, and creative coding."
      enableSignature
    />

    <SectionDivider variant="wave" class="mb-6" />

    <BlogFilterBar allTags={blogTags} />

    <ul class="space-y-6 list-none p-0" data-reveal data-reveal-stagger="children">
      {
        allPosts.map((post) => (
          <div data-tags={post.tags.join(",")} data-filter-item>
            <PostCard
              title={post.title}
              slug={post.slug}
              excerpt={post.excerpt}
              tags={post.tags}
              publishedAt={post.publishedAt.toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            />
          </div>
        ))
      }
    </ul>

    <p
      id="empty-state"
      class="hidden text-(--color-text-muted) text-center py-12"
    >
      No posts match this filter.
    </p>
  </section>
  <SignatureInit />
  <DividerInit />
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const tag = params.get("tag");

  if (tag) {
    const items = document.querySelectorAll<HTMLElement>("[data-filter-item]");
    let visible = 0;

    items.forEach((el) => {
      const elTags = el.dataset.tags?.split(",") ?? [];
      if (elTags.includes(tag)) {
        visible++;
      } else {
        el.style.display = "none";
      }
    });

    if (visible === 0) {
      document.getElementById("empty-state")?.classList.remove("hidden");
    }

    const current = window.location.pathname + window.location.search;
    document
      .querySelectorAll<HTMLElement>("[data-pill-href]")
      .forEach((pill) => {
        if (pill.dataset.pillHref === current) {
          pill.setAttribute("data-pill-active", "");
        } else {
          pill.removeAttribute("data-pill-active");
        }
      });
  }
</script>
