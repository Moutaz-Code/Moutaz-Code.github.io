---
import { contentSource } from "../../app/content";
import BaseLayout from "../../ui/layouts/BaseLayout.astro";
import TagChip from "../../ui/components/content/TagChip.astro";
import PostCard from "../../ui/components/content/PostCard.astro";
import Prose from "../../ui/components/content/Prose.astro";
import ResponsiveImage from "../../ui/components/content/ResponsiveImage.astro";

export async function getStaticPaths() {
  const posts = await contentSource.listPosts();
  return posts.map((p) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const post = await contentSource.getPostBySlug(slug!);
if (!post) return Astro.redirect("/404");

const { title, excerpt, publishedAt, tags, coverImage, content } = post;
const { Content } = content;

const formattedDate = publishedAt.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

// Related posts: share at least one tag, exclude current, max 3
const allPosts = await contentSource.listPosts();
const relatedPosts = allPosts
  .filter((p) => p.slug !== slug && p.tags.some((t) => tags.includes(t)))
  .slice(0, 3);
---

<BaseLayout title={title} description={excerpt} ogType="article" ogImage={coverImage}>
  <article class="py-8" data-pagefind-body>
    <div class="mb-8" data-pagefind-ignore>
      <a
        href="/blog"
        class="text-sm text-(--color-text-muted) hover:text-(--color-accent) no-underline"
      >
        &larr; Back to Blog
      </a>
    </div>

    <h1 class="text-3xl font-bold tracking-tight mb-3">{title}</h1>
    <span data-pagefind-meta="type:Post" class="hidden"></span>
    <span data-pagefind-meta={`tags:${tags.join(",")}`} class="hidden"></span>

    <div class="flex items-center gap-3 mb-6 text-sm text-(--color-text-muted) flex-wrap">
      <time datetime={publishedAt.toISOString()}>{formattedDate}</time>
      <span>&middot;</span>
      <div class="flex gap-2 flex-wrap">
        {tags.map((tag) => <TagChip tag={tag} />)}
      </div>
    </div>

    {
      coverImage && (
        <ResponsiveImage
          src={coverImage}
          alt={title}
          variant="hero"
          class="rounded-lg border border-(--color-border) w-full mb-8"
        />
      )
    }

    <Prose>
      <Content />
    </Prose>

    <div data-pagefind-ignore>
    {
      tags.length > 0 && (
        <div class="mt-10 pt-6 border-t border-(--color-border)">
          <p class="text-sm text-(--color-text-muted) mb-3">
            Browse more with these tags:
          </p>
          <div class="flex gap-2 flex-wrap">
            {tags.map((tag) => (
              <TagChip tag={tag} href={`/blog?tag=${tag}`} />
            ))}
          </div>
        </div>
      )
    }

    {
      relatedPosts.length > 0 && (
        <div class="mt-10 pt-6 border-t border-(--color-border)">
          <h2 class="text-lg font-semibold mb-4">Related Posts</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {relatedPosts.map((rp) => (
              <PostCard
                title={rp.title}
                slug={rp.slug}
                excerpt={rp.excerpt}
                tags={rp.tags}
                publishedAt={rp.publishedAt}
                coverImage={rp.coverImage}
              />
            ))}
          </div>
        </div>
      )
    }
    </div>
  </article>
</BaseLayout>
