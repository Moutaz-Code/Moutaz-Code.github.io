---
import BaseLayout from "../ui/layouts/BaseLayout.astro";
import ButtonLink from "../ui/components/primitives/ButtonLink.astro";
---

<BaseLayout
  title="Resume"
  description="Download my resume or view it online."
  enableMotion
  enableSmoothScroll
  enableAmbient
  ambientVariant="b"
  enableCursor
  enablePageTransitions
  enableSound
>
  <section class="py-8">
    <h1 class="text-3xl font-bold tracking-tight mb-2">Resume</h1>
    <p class="text-(--color-text-muted) mb-8">
      Download a copy of my resume or view the highlights below.
    </p>

    <div class="flex gap-3 mb-10 flex-wrap">
      <ButtonLink href="/resume.pdf" variant="primary" magnetic>
        Download PDF
      </ButtonLink>
      <ButtonLink href="/resume.pdf" variant="secondary" external>
        Open in New Tab
      </ButtonLink>
    </div>

    <!-- Resume Highlights -->
    <div class="mb-10" data-reveal>
      <h2 class="text-xl font-semibold mb-4">Highlights</h2>
      <ul class="space-y-2 text-sm">
        <li class="flex gap-2">
          <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-(--color-accent)"></span>
          <span>Passionate about building polished, performant web experiences</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-(--color-accent)"></span>
          <span>Strong focus on TypeScript, modern frameworks, and clean architecture</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-(--color-accent)"></span>
          <span>Experience with game development using Unity and C#</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-(--color-accent)"></span>
          <span>Comfortable working across the full stack — frontend, backend, and tooling</span>
        </li>
      </ul>
    </div>

    <!-- Resume sections -->
    <div class="space-y-8">
      <div>
        <h2 class="text-xl font-semibold mb-3">Education</h2>
        <div class="border-l-2 border-(--color-border) pl-4">
          <p class="font-medium">B.S. Computer Science</p>
          <p class="text-sm text-(--color-text-muted)">
            University Name &middot; 2022 – 2026
          </p>
        </div>
      </div>

      <div>
        <h2 class="text-xl font-semibold mb-3">Experience</h2>
        <div class="border-l-2 border-(--color-border) pl-4 space-y-4">
          <div>
            <p class="font-medium">Software Engineering Intern</p>
            <p class="text-sm text-(--color-text-muted)">
              Company Name &middot; Summer 2025
            </p>
            <p class="text-sm text-(--color-text-muted) mt-1">
              Worked on internal tooling and API development.
            </p>
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-xl font-semibold mb-3">Skills</h2>
        <p class="text-sm text-(--color-text-muted)">
          TypeScript, JavaScript, C#, Python, React, Astro, Node.js, Unity,
          Tailwind CSS, .NET, Git, WebGL
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
