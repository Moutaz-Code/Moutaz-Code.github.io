---
import { contentSource } from "../../app/content";
import BaseLayout from "../../ui/layouts/BaseLayout.astro";
import TagChip from "../../ui/components/content/TagChip.astro";
import StatusBadge from "../../ui/components/content/StatusBadge.astro";
import MediaGallery from "../../ui/components/content/MediaGallery.astro";
import ProjectCard from "../../ui/components/content/ProjectCard.astro";
import Prose from "../../ui/components/content/Prose.astro";
import ButtonLink from "../../ui/components/primitives/ButtonLink.astro";
import CornerFlourish from "../../ui/components/signature/CornerFlourish.astro";
import CornerSpark from "../../ui/components/signature/CornerSpark.astro";
import SignatureInit from "../../ui/components/signature/SignatureInit.astro";
import QuickFacts from "../../ui/components/projects/QuickFacts.astro";
import Highlights from "../../ui/components/projects/Highlights.astro";
import Results from "../../ui/components/projects/Results.astro";

export async function getStaticPaths() {
  const projects = await contentSource.listProjects();
  return projects.map((p) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const project = await contentSource.getProjectBySlug(slug!);
if (!project) return Astro.redirect("/404");

const {
  title, summary, status, tags, links, media, content, dateStart, dateEnd,
  role, timeframe, stack, highlights, results,
  problem, constraints, approach, architecture, challenges, lessons, nextSteps,
} = project;
const { Content } = content;

// Related projects: share at least one tag, exclude current, max 3
const allProjects = await contentSource.listProjects();
const relatedProjects = allProjects
  .filter((p) => p.slug !== slug && p.tags.some((t) => tags.includes(t)))
  .slice(0, 3);

// Determine if we have case study content to show the two-column layout
const hasQuickFacts = role || timeframe || stack.length > 0 || links.length > 0;
const hasHighlightsOrResults = highlights.length > 0 || results.length > 0;
const hasTwoColumnContent = hasQuickFacts || hasHighlightsOrResults;

// Case study sections — array of { title, items } for bullet lists, or { title, text } for paragraphs
const caseSections = [
  { title: "Problem", text: problem },
  { title: "Constraints", items: constraints },
  { title: "Approach", items: approach },
  { title: "Architecture", items: architecture },
  { title: "Challenges", items: challenges },
  { title: "Lessons Learned", items: lessons },
  { title: "Next Steps", items: nextSteps },
].filter((s) => ("text" in s && s.text) || ("items" in s && s.items && s.items.length > 0));
---

<BaseLayout title={title} description={summary} ogImage={project.primaryImage?.src} enableMotion enableSmoothScroll enableAmbient ambientVariant="b" enableCursor enablePageTransitions enableSound>
  <article class="py-8" data-pagefind-body>
    <div class="mb-8" data-pagefind-ignore>
      <a
        href="/projects"
        class="text-sm text-(--color-text-muted) hover:text-(--color-accent) no-underline"
      >
        &larr; Back to Projects
      </a>
    </div>

    <!-- Header -->
    <div class="relative">
      <CornerFlourish position="top-right" />
      <CornerSpark position="top-right" />
      <h1 class="text-3xl font-bold tracking-tight mb-3" data-reveal>{title}</h1>
      <span data-pagefind-meta="type:Project" class="hidden"></span>
      <span data-pagefind-meta={`tags:${tags.join(",")}`} class="hidden"></span>

      <p class="text-(--color-text-muted) mb-4" data-reveal>{summary}</p>

      <div class="flex items-center gap-3 mb-6 flex-wrap">
        <StatusBadge status={status} />
        <div class="flex gap-2 flex-wrap">
          {tags.map((tag) => <TagChip tag={tag} />)}
        </div>
      </div>
    </div>

    <!-- Two-column: Highlights/Results + Quick Facts -->
    {
      hasTwoColumnContent && (
        <div class:list={[
          "mb-8",
          hasQuickFacts && hasHighlightsOrResults ? "lg:grid lg:grid-cols-[1fr_260px] lg:gap-8" : "",
        ]}>
          {/* Left: Highlights + Results */}
          {hasHighlightsOrResults && (
            <div>
              <Highlights items={highlights} />
              <Results items={results} />
            </div>
          )}

          {/* Right: Quick Facts */}
          {hasQuickFacts && (
            <div class:list={[hasHighlightsOrResults ? "lg:sticky lg:top-24 lg:self-start" : ""]}>
              <QuickFacts
                status={status}
                role={role}
                timeframe={timeframe}
                stack={stack}
                links={links}
              />
            </div>
          )}
        </div>
      )
    }

    <!-- Media gallery -->
    {
      media.length > 0 && (
        <div class="mb-8">
          <MediaGallery items={media} />
        </div>
      )
    }

    <!-- Case study sections -->
    {
      caseSections.length > 0 && (
        <div class="space-y-8 mb-8" data-reveal>
          {caseSections.map((section) => (
            <div>
              <h2 class="text-lg font-semibold mb-3">{section.title}</h2>
              {"text" in section && section.text ? (
                <p class="text-sm text-(--color-text-muted)">{section.text}</p>
              ) : "items" in section && section.items ? (
                <ul class="space-y-1.5 text-sm list-disc pl-5 text-(--color-text-muted)">
                  {section.items.map((item: string) => (
                    <li>{item}</li>
                  ))}
                </ul>
              ) : null}
            </div>
          ))}
        </div>
      )
    }

    <!-- MDX body -->
    <Prose>
      <Content />
    </Prose>

    <!-- Contact CTA -->
    <div class="mt-10 pt-6 border-t border-(--color-border) text-center" data-pagefind-ignore>
      <p class="text-(--color-text-muted) mb-3">Interested in this project?</p>
      <ButtonLink href="/contact" variant="primary" magnetic>
        Get in Touch
      </ButtonLink>
    </div>

    <!-- Browse more -->
    <div data-pagefind-ignore>
    {
      tags.length > 0 && (
        <div class="mt-10 pt-6 border-t border-(--color-border)">
          <p class="text-sm text-(--color-text-muted) mb-3">
            Browse more with these tags:
          </p>
          <div class="flex gap-2 flex-wrap">
            {tags.map((tag) => (
              <TagChip tag={tag} href={`/projects?tag=${tag}`} />
            ))}
          </div>
        </div>
      )
    }

    {
      relatedProjects.length > 0 && (
        <div class="mt-10 pt-6 border-t border-(--color-border)">
          <h2 class="text-lg font-semibold mb-4">Related Projects</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {relatedProjects.map((rp) => (
              <ProjectCard
                title={rp.title}
                slug={rp.slug}
                summary={rp.summary}
                tags={rp.tags}
                status={rp.status}
                featured={rp.featured}
                primaryImage={rp.primaryImage}
              />
            ))}
          </div>
        </div>
      )
    }
    </div>
  </article>
  <SignatureInit />
</BaseLayout>
