---
import { contentSource } from "../../app/content";
import BaseLayout from "../../ui/layouts/BaseLayout.astro";
import PageHeader from "../../ui/components/primitives/PageHeader.astro";
import TagChip from "../../ui/components/content/TagChip.astro";

const allTags = await contentSource.listTags();
---

<BaseLayout title="Tags" description="Browse projects and posts by topic." enableMotion enableSmoothScroll>
  <section class="py-8">
    <PageHeader
      title="Tags"
      subtitle="Browse projects and posts by topic."
    />

    <div class="space-y-4" data-reveal data-reveal-stagger="children">
      {
        allTags.map((tag) => (
          <a
            href={`/tags/${tag.slug}`}
            class="inline-flex items-center gap-2 mr-3 mb-2 no-underline group"
          >
            <TagChip tag={tag.slug} size="md" />
            <span class="text-xs text-(--color-text-muted)">
              {tag.countTotal}
            </span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
