---
import { contentSource } from "../../app/content";
import BaseLayout from "../../ui/layouts/BaseLayout.astro";
import PageHeader from "../../ui/components/primitives/PageHeader.astro";
import Section from "../../ui/components/primitives/Section.astro";
import ProjectCard from "../../ui/components/content/ProjectCard.astro";
import PostCard from "../../ui/components/content/PostCard.astro";

export async function getStaticPaths() {
  const allTags = await contentSource.listTags();
  return allTags.map((t) => ({
    params: { tag: t.slug },
    props: { label: t.label },
  }));
}

const { tag } = Astro.params;
const { label } = Astro.props;
const projects = await contentSource.listProjects({ tag });
const posts = await contentSource.listPosts({ tag });
---

<BaseLayout
  title={`#${label}`}
  description={`Projects and posts tagged "${label}".`}
  enableSmoothScroll
  enableAmbient
  ambientVariant="c"
  enableCursor
  enablePageTransitions
  enableSound
>
  <section class="py-8">
    <div class="mb-8">
      <a
        href="/tags"
        class="text-sm text-(--color-text-muted) hover:text-(--color-accent) no-underline"
      >
        &larr; All Tags
      </a>
    </div>

    <PageHeader title={`#${label}`} subtitle={`Projects and posts tagged "${label}".`} />

    {
      projects.length > 0 && (
        <Section title="Projects">
          <div class="grid gap-6 sm:grid-cols-2">
            {projects.map((project) => (
              <ProjectCard
                title={project.title}
                slug={project.slug}
                summary={project.summary}
                tags={project.tags}
                status={project.status}
                featured={project.featured}
                primaryImage={project.primaryImage}
              />
            ))}
          </div>
        </Section>
      )
    }

    {
      posts.length > 0 && (
        <Section title="Posts">
          <ul class="space-y-4 list-none p-0">
            {posts.map((post) => (
              <PostCard
                title={post.title}
                slug={post.slug}
                excerpt={post.excerpt}
                tags={post.tags}
                publishedAt={post.publishedAt?.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              />
            ))}
          </ul>
        </Section>
      )
    }

    {
      projects.length === 0 && posts.length === 0 && (
        <p class="text-(--color-text-muted) py-8">
          No projects or posts with this tag yet.
        </p>
      )
    }
  </section>
</BaseLayout>
