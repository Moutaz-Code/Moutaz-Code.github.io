---
// SoundToggle — speaker icon button, toggles micro sound effects
---

<button
  id="sound-toggle"
  type="button"
  aria-pressed="false"
  aria-label="Toggle sound effects"
  class="sound-toggle"
  data-sfx="toggle"
>
  <!-- Speaker-off icon (default/muted) -->
  <svg id="icon-speaker-off" class="sound-toggle__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
    <line x1="23" y1="9" x2="17" y2="15" />
    <line x1="17" y1="9" x2="23" y2="15" />
  </svg>
  <!-- Speaker-on icon (enabled) -->
  <svg id="icon-speaker-on" class="sound-toggle__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
    <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
    <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
  </svg>
</button>

<style>
  .sound-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    background: none;
    padding: 4px;
    border-radius: 6px;
    outline: none;
    width: 28px;
    height: 28px;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
    position: relative;
  }

  .sound-toggle:hover {
    color: var(--color-text);
  }

  .sound-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .sound-toggle__icon {
    width: 16px;
    height: 16px;
    position: absolute;
    transition: opacity 0.2s ease;
  }

  /* Muted by default: speaker-off visible, speaker-on hidden */
  #icon-speaker-off { opacity: 1; }
  #icon-speaker-on  { opacity: 0; }

  /* When sound enabled: swap icons */
  :global(html.sound-on) #icon-speaker-off { opacity: 0; }
  :global(html.sound-on) #icon-speaker-on  { opacity: 1; }
  :global(html.sound-on) .sound-toggle {
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .sound-toggle__icon {
      transition: none;
    }
  }
</style>

<script>
  import { toggleSound, isEnabled } from "../../app/sound";

  const btn = document.getElementById("sound-toggle") as HTMLButtonElement;
  const enabled = isEnabled();

  btn.setAttribute("aria-pressed", String(enabled));
  if (enabled) {
    document.documentElement.classList.add("sound-on");
  }

  btn.addEventListener("click", () => {
    const next = toggleSound();
    const on = next === "on";
    btn.setAttribute("aria-pressed", String(on));
    document.documentElement.classList.toggle("sound-on", on);
  });
</script>
