---
// CursorLayer — custom cursor DOM (dot + ring + label).
// All positioning handled by CursorInit. Pure presentation.
import "../../../styles/cursor.css";
---

<div class="cursor-root" id="cursor-root" aria-hidden="true">
  <div class="cursor-dot" id="cursor-dot"></div>
  <div class="cursor-ring" id="cursor-ring"></div>
  <div class="cursor-label" id="cursor-label"></div>
</div>
