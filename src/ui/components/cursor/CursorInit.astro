---
// CursorInit — pointer tracking, hover state detection, RAF animation loop.
// Include once after CursorLayer to activate the custom cursor.
---

<script>
  const reduced =
    typeof window !== "undefined" &&
    window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const isCoarse =
    typeof window !== "undefined" &&
    window.matchMedia("(pointer: coarse)").matches;

  const root = document.getElementById("cursor-root");
  const dot = document.getElementById("cursor-dot");
  const ring = document.getElementById("cursor-ring");
  const label = document.getElementById("cursor-label");

  if (!reduced && !isCoarse && root && dot && ring && label) {
    // Activate the cursor layer
    root.classList.add("cursor--active");
    document.documentElement.classList.add("cursor-active");

    // ── Pointer state ──────────────────────────────────
    let targetX = -100;
    let targetY = -100;
    let dotX = -100;
    let dotY = -100;
    let ringX = -100;
    let ringY = -100;

    const DOT_LERP = 0.55;
    const RING_LERP = 0.15;

    let currentState = "default";

    // ── Pointer tracking ───────────────────────────────
    document.addEventListener("pointermove", (e) => {
      targetX = e.clientX;
      targetY = e.clientY;
    });

    // ── Hide when pointer leaves window ────────────────
    document.addEventListener("pointerleave", () => {
      root.classList.add("cursor--hidden");
    });

    document.addEventListener("pointerenter", () => {
      root.classList.remove("cursor--hidden");
    });

    // ── Hover state detection (event delegation) ───────
    function getCursorState(el: Element | null): { state: string; labelText: string } {
      if (!el) return { state: "default", labelText: "" };

      // Walk up from target to find interactive element
      let node: Element | null = el;
      while (node && node !== document.documentElement) {
        // Explicit data-cursor attribute takes priority
        const explicit = node.getAttribute("data-cursor");
        if (explicit) {
          return {
            state: explicit,
            labelText: node.getAttribute("data-cursor-label") ?? "",
          };
        }

        // Input fields → text state
        const tag = node.tagName.toLowerCase();
        if (
          tag === "input" ||
          tag === "textarea" ||
          tag === "select" ||
          (node as HTMLElement).isContentEditable
        ) {
          return { state: "text", labelText: "" };
        }

        // Buttons
        if (tag === "button" || node.getAttribute("role") === "button") {
          return {
            state: "button",
            labelText: node.getAttribute("data-cursor-label") ?? "",
          };
        }

        // Links
        if (tag === "a") {
          return {
            state: "link",
            labelText: node.getAttribute("data-cursor-label") ?? "",
          };
        }

        // Cards (elements with data-hover="lift" are typically cards)
        if (node.getAttribute("data-hover") === "lift") {
          return {
            state: "card",
            labelText: node.getAttribute("data-cursor-label") ?? "",
          };
        }

        node = node.parentElement;
      }

      return { state: "default", labelText: "" };
    }

    function applyState(state: string, labelText: string) {
      if (state === currentState && label.textContent === labelText) return;

      // Remove old state class
      root.classList.remove(`cursor--${currentState}`);
      currentState = state;
      root.classList.add(`cursor--${currentState}`);

      // Label
      if (labelText) {
        label.textContent = labelText;
        label.classList.add("cursor-label--visible");
      } else {
        label.classList.remove("cursor-label--visible");
      }
    }

    document.addEventListener("pointerover", (e) => {
      const { state, labelText } = getCursorState(e.target as Element);
      applyState(state, labelText);
    });

    document.addEventListener("pointerout", (e) => {
      // Only reset if we're leaving to a non-interactive element
      const related = (e as PointerEvent).relatedTarget as Element | null;
      const { state, labelText } = getCursorState(related);
      applyState(state, labelText);
    });

    // ── Animation loop ─────────────────────────────────
    function tick() {
      // Lerp dot (snappy)
      dotX += (targetX - dotX) * DOT_LERP;
      dotY += (targetY - dotY) * DOT_LERP;

      // Lerp ring (laggy)
      ringX += (targetX - ringX) * RING_LERP;
      ringY += (targetY - ringY) * RING_LERP;

      dot.style.left = `${dotX}px`;
      dot.style.top = `${dotY}px`;

      ring.style.left = `${ringX}px`;
      ring.style.top = `${ringY}px`;

      label.style.left = `${dotX}px`;
      label.style.top = `${dotY}px`;

      requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }
</script>
