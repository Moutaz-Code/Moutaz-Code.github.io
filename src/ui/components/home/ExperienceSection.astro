---
import Section from "../primitives/Section.astro";
import { profileConfig } from "../../../app/profileConfig";
---

<Section title="Experience" subtitle="Where I've worked and what I've studied.">
  <ul class="space-y-4" data-reveal data-reveal-stagger="children">
    {
      profileConfig.experience.map((item) => (
        <li class="flex gap-4">
          <span class="mt-1.5 block h-2 w-2 shrink-0 rounded-full bg-(--color-accent)" />
          <div>
            <p class="font-medium">{item.title}</p>
            <p class="text-sm text-(--color-text-muted)">
              {item.org} &middot; {item.period}
            </p>
          </div>
        </li>
      ))
    }
  </ul>
</Section>
