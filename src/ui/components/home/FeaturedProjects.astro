---
import Section from "../primitives/Section.astro";
import ProjectCard from "../content/ProjectCard.astro";
import type { ProjectSummary } from "../../../domain/models/view/ProjectView";

interface Props {
  projects: ProjectSummary[];
}

const { projects } = Astro.props;
---

<Section title="Featured Projects" subtitle="A few things I've built.">
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal data-reveal-stagger="children">
    {
      projects.map((project) => (
        <ProjectCard
          title={project.title}
          slug={project.slug}
          summary={project.summary}
          tags={project.tags}
          status={project.status}
          featured={project.featured}
          primaryImage={project.primaryImage}
        />
      ))
    }
  </div>
  <p class="mt-6">
    <a href="/projects" class="text-sm font-medium">See all projects &rarr;</a>
  </p>
</Section>
