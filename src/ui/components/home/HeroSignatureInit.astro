---
// HeroSignatureInit — dynamically imports anime.js and kicks off the hero
// signature timeline. Placed only on the homepage so anime.js never loads
// on other pages.
---

<script>
  const root = document.querySelector<HTMLElement>(
    "[data-hero-signature-root]"
  );
  if (root) {
    import("../../anime/heroSignature").then(({ initHeroSignature }) => {
      initHeroSignature(root);
    });
  }
</script>
