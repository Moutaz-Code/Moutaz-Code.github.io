---
// ConstellationInit — IntersectionObserver-gated RAF loop for the
// constellation animation. Dynamically imports the constellation module.
// When the container scrolls out of view, the RAF loop pauses.
// Also pauses when the tab is hidden (visibilitychange).
// Include once per page (after ProjectConstellation DOM).
---

<script>
  const root = document.querySelector<HTMLElement>(
    "[data-constellation-root]",
  );

  if (root) {
    import("../../motion/constellation").then(({ initConstellation }) => {
      initConstellation(root);

      const constellation = (root as any).__constellation;
      if (!constellation) return;

      let isIntersecting = false;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            isIntersecting = entry.isIntersecting;
            if (isIntersecting && !document.hidden) {
              constellation.start();
            } else {
              constellation.stop();
            }
          });
        },
        { threshold: 0.1 },
      );

      observer.observe(root);

      // Pause when tab is hidden, resume when visible + intersecting
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          constellation.stop();
        } else if (isIntersecting) {
          constellation.start();
        }
      });
    });
  }
</script>
