---
import Section from "../primitives/Section.astro";
import { profileConfig } from "../../../app/profileConfig";
---

<Section title="Skills" subtitle="Technologies I work with regularly.">
  <div class="flex gap-2 flex-wrap">
    {
      profileConfig.skills.map((skill) => (
        <span class="inline-block rounded-full border border-(--color-border) px-3 py-1 text-xs font-medium text-(--color-text-muted)">
          {skill}
        </span>
      ))
    }
  </div>
</Section>
