---
import Section from "../primitives/Section.astro";
import { profileConfig } from "../../../app/profileConfig";
---

<Section title="Skills" subtitle="Technologies I work with regularly.">
  <div class="flex flex-col gap-5" data-reveal>
    {profileConfig.skills.map((group) => (
      <div>
        <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-(--color-text-muted)">{group.group}</div>
        <div class="flex gap-2 flex-wrap" data-reveal-stagger="children">
          {group.items.map((skill) => (
            <span class="inline-block rounded-full border border-(--color-border) px-3 py-1 text-xs font-medium text-(--color-text-muted)">{skill}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</Section>
