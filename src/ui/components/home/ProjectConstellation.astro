---
import "../../../styles/constellation.css";
import type { ProjectSummary } from "../../../domain/models/view/ProjectView";

interface Props {
  projects: ProjectSummary[];
}

const { projects } = Astro.props;

// ── Hash function for deterministic positions ─────────
function hashSlug(slug: string): number {
  let h = 0;
  for (let i = 0; i < slug.length; i++) {
    h = ((h << 5) - h + slug.charCodeAt(i)) | 0;
  }
  return Math.abs(h);
}

// ── Compute base positions from slug hash ─────────────
const PADDING = 12;
const RANGE = 100 - PADDING * 2;

type NodePosition = {
  x: number;
  y: number;
  slug: string;
  title: string;
  tags: string[];
  href: string;
  phase: number;
  freqX: number;
  freqY: number;
};

const positions: NodePosition[] = projects.map((p) => {
  const h = hashSlug(p.slug);
  return {
    x: PADDING + ((h % 1000) / 1000) * RANGE,
    y: PADDING + (((h >> 10) % 1000) / 1000) * RANGE,
    slug: p.slug,
    title: p.title,
    tags: p.tags.slice(0, 3),
    href: `/projects/${p.slug}`,
    phase: ((h >> 20) % 628) / 100,
    freqX: 0.3 + ((h >> 5) % 30) / 100,
    freqY: 0.3 + ((h >> 8) % 30) / 100,
  };
});

// ── Relaxation pass for minimum separation ────────────
const MIN_DIST = 18;
const ITERATIONS = 12;

for (let iter = 0; iter < ITERATIONS; iter++) {
  for (let i = 0; i < positions.length; i++) {
    for (let j = i + 1; j < positions.length; j++) {
      const dx = positions[j].x - positions[i].x;
      const dy = positions[j].y - positions[i].y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < MIN_DIST && dist > 0) {
        const push = (MIN_DIST - dist) / 2;
        const nx = dx / dist;
        const ny = dy / dist;
        positions[i].x -= nx * push;
        positions[i].y -= ny * push;
        positions[j].x += nx * push;
        positions[j].y += ny * push;
      }
    }
    positions[i].x = Math.max(PADDING, Math.min(100 - PADDING, positions[i].x));
    positions[i].y = Math.max(PADDING, Math.min(100 - PADDING, positions[i].y));
  }
}

// ── Compute nearest-neighbor lines ────────────────────
type LineData = { fromSlug: string; toSlug: string; x1: number; y1: number; x2: number; y2: number; phase: number };
const lineSet = new Set<string>();
const lines: LineData[] = [];

for (let i = 0; i < positions.length; i++) {
  let nearestIdx = -1;
  let nearestDist = Infinity;
  for (let j = 0; j < positions.length; j++) {
    if (i === j) continue;
    const dx = positions[j].x - positions[i].x;
    const dy = positions[j].y - positions[i].y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < nearestDist) {
      nearestDist = dist;
      nearestIdx = j;
    }
  }
  if (nearestIdx >= 0) {
    const key = [Math.min(i, nearestIdx), Math.max(i, nearestIdx)].join("-");
    if (!lineSet.has(key)) {
      lineSet.add(key);
      // Derive a deterministic wave phase from both slugs
      const linePhase = ((hashSlug(positions[i].slug + positions[nearestIdx].slug) >> 3) % 628) / 100;
      lines.push({
        fromSlug: positions[i].slug,
        toSlug: positions[nearestIdx].slug,
        x1: positions[i].x,
        y1: positions[i].y,
        x2: positions[nearestIdx].x,
        y2: positions[nearestIdx].y,
        phase: linePhase,
      });
    }
  }
}

// ── Serialize data for client-side animation ──────────
const constellationJSON = JSON.stringify({
  nodes: positions.map((p) => ({
    slug: p.slug,
    baseX: p.x,
    baseY: p.y,
    phase: p.phase,
    freqX: p.freqX,
    freqY: p.freqY,
  })),
  lines: lines.map((l) => ({
    from: l.fromSlug,
    to: l.toSlug,
    phase: l.phase,
  })),
});
---

<section
  class="constellation-root"
  data-constellation-root
  aria-label="Featured project constellation"
>
  <svg class="constellation-lines" aria-hidden="true">
    {lines.map((line) => (
      <line
        class="constellation-line"
        x1={`${line.x1}%`}
        y1={`${line.y1}%`}
        x2={`${line.x2}%`}
        y2={`${line.y2}%`}
      />
    ))}
  </svg>

  {positions.map((node) => (
    <a
      class="constellation-node"
      href={node.href}
      style={`left: ${node.x}%; top: ${node.y}%;`}
      data-constellation-node
      data-slug={node.slug}
      data-tooltip-below={node.y < 20 ? "" : undefined}
      data-cursor="link"
      data-cursor-label={node.title}
      aria-label={`${node.title}${node.tags.length > 0 ? ` — ${node.tags.join(", ")}` : ""}`}
    >
      <div class="constellation-glow" aria-hidden="true"></div>
      <svg width="36" height="36" viewBox="0 0 36 36" aria-hidden="true">
        <circle class="constellation-ring" cx="18" cy="18" r="14" />
        <circle class="constellation-dot" cx="18" cy="18" r="4" />
      </svg>
      <div class="constellation-tooltip" role="tooltip">
        <div>{node.title}</div>
        {node.tags.length > 0 && (
          <div class="constellation-tooltip-tags">
            {node.tags.join(" · ")}
          </div>
        )}
      </div>
    </a>
  ))}

  <script type="application/json" data-constellation-data set:html={constellationJSON} />
</section>
