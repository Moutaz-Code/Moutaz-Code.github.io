---
import ButtonLink from "../primitives/ButtonLink.astro";
---

<section class="py-10 sm:py-12 text-center" data-reveal>
  <h2 class="text-xl sm:text-2xl font-bold tracking-tight mb-2">Get in Touch</h2>
  <p class="text-sm sm:text-base text-(--color-text-muted) mb-5 sm:mb-6">
    Have a project idea or just want to say hi?
  </p>
  <ButtonLink href="/contact" variant="primary">Contact Me</ButtonLink>
</section>
