---
// HeroSignature — wraps the hero section with the signature stroke + bloom.
// Adds an SVG underline path and an optional accent bloom element.
// Animation is handled by HeroSignatureInit (anime.js, loaded only on homepage).
import "../../../styles/anime-signature.css";
import ButtonLink from "../primitives/ButtonLink.astro";
import { profileConfig } from "../../../app/profileConfig";
import { siteConfig } from "../../../app/siteConfig";
---

<section
  class="py-10 sm:py-24 relative"
  data-hero-signature-root
  data-reveal
  data-reveal-stagger="children"
>
  <p
    class="text-sm font-medium tracking-wide uppercase text-(--color-accent) mb-3"
  >
    {profileConfig.role}
  </p>
  <h1
    class="text-3xl sm:text-5xl font-bold tracking-tight leading-tight mb-1"
    data-accent="pop"
  >
    Hi, I'm {profileConfig.name}
  </h1>

  <!-- Signature stroke underline -->
  <svg
    class="hero-signature-svg"
    data-hero-signature-svg
    width="220"
    height="14"
    viewBox="0 0 220 14"
    aria-hidden="true"
  >
    <path
      class="hero-signature-path"
      data-hero-signature-path
      d="M2 10 C 40 2, 80 2, 120 8 S 180 12, 218 4"
    />
  </svg>

  <div class="h-3" aria-hidden="true"></div>

  <p class="text-base sm:text-lg text-(--color-text-muted) max-w-xl mb-6 sm:mb-8">
    {profileConfig.pitch}
  </p>
  <div class="flex flex-col gap-3 sm:gap-4 lg:flex-row lg:items-center lg:gap-6">
    <div class="flex gap-4 relative">
      <!-- Bloom glow behind CTAs -->
      <div class="hero-bloom" data-hero-bloom aria-hidden="true"></div>
      {
        profileConfig.ctas.map((cta) => (
          <ButtonLink
            href={cta.href}
            variant={cta.variant}
            cursorLabel={cta.variant === "primary" ? "Explore" : undefined}
            magnetic={cta.variant === "primary"}
          >
            {cta.label}
          </ButtonLink>
        ))
      }
    </div>

    {(siteConfig.socialLinks.email || siteConfig.socialLinks.linkedin) && (
      <div class="flex flex-wrap items-center gap-y-2 text-xs sm:text-sm text-(--color-text-muted)">
        
        {siteConfig.socialLinks.email && (
          <a
            href={siteConfig.socialLinks.email}
            class="no-underline/80 hover:no-underline text-(--color-text-muted) hover:text-(--color-text) transition-colors"
          >
            Email
          </a>
        )}
        {siteConfig.socialLinks.email && siteConfig.socialLinks.linkedin && (
          <span aria-hidden="true" class="mx-2 opacity-40">•</span>
        )}
        {siteConfig.socialLinks.linkedin && (
          <a
            href={siteConfig.socialLinks.linkedin}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1 no-underline/80 hover:no-underline text-(--color-text-muted) hover:text-(--color-text) transition-colors"
          >
            <span>LinkedIn</span>
            <span aria-hidden="true" class="text-[0.72em] opacity-60">↗</span>
          </a>
        )}
      </div>
    )}
  </div>
</section>
