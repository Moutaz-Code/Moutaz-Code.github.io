---
import Card from "./Card.astro";
import TagChip from "./TagChip.astro";

interface Props {
  title: string;
  summary: string;
  slug: string;
  tags: string[];
  status: "ongoing" | "completed";
  featured: boolean;
  image?: string;
}

const { title, summary, slug, tags, status, featured, image } = Astro.props;
---

<Card href={`/projects/${slug}`}>
  {
    image && (
      <img
        src={image}
        alt={title}
        class="rounded mb-3 w-full h-36 object-cover"
        loading="lazy"
      />
    )
  }
  <div class="flex items-center justify-between mb-2">
    <h3 class="font-semibold">{title}</h3>
    <span
      class:list={[
        "text-xs px-2 py-0.5 rounded-full shrink-0",
        status === "ongoing"
          ? "bg-green-100 text-green-700"
          : "bg-gray-100 text-(--color-text-muted)",
      ]}
    >
      {status}
    </span>
  </div>
  <p class="text-sm text-(--color-text-muted) mb-3">{summary}</p>
  <div class="flex gap-2 flex-wrap">
    {tags.map((tag) => <TagChip tag={tag} />)}
  </div>
</Card>
