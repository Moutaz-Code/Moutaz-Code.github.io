---
interface Props {
  tag: string;
  href?: string;
}

const { tag, href } = Astro.props;
---

{
  href ? (
    <a
      href={href}
      class="inline-block rounded-full border border-(--color-border) px-3 py-1 text-xs font-medium text-(--color-text-muted) no-underline hover:border-(--color-accent) hover:text-(--color-accent) transition-colors"
    >
      {tag}
    </a>
  ) : (
    <span class="inline-block rounded-full border border-(--color-border) px-3 py-1 text-xs font-medium text-(--color-text-muted)">
      {tag}
    </span>
  )
}
