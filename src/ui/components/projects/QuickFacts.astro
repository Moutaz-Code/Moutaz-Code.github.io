---
import type { ProjectStatus } from "../../../domain/models/Project";
import type { Link } from "../../../domain/models/Link";
import StatusBadge from "../content/StatusBadge.astro";
import ButtonLink from "../primitives/ButtonLink.astro";

interface Props {
  status: ProjectStatus;
  role?: string;
  timeframe?: string;
  stack?: string[];
  links?: Link[];
}

const { status, role, timeframe, stack = [], links = [] } = Astro.props;

const hasContent = role || timeframe || stack.length > 0 || links.length > 0;
---

{
  hasContent && (
    <div class="rounded-lg border border-(--color-border) p-5" data-reveal>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-(--color-text-muted) mb-4">
        Quick Facts
      </h3>

      <dl class="space-y-3 text-sm">
        {/* Status */}
        <div class="flex items-center justify-between">
          <dt class="text-(--color-text-muted)">Status</dt>
          <dd><StatusBadge status={status} /></dd>
        </div>

        {/* Role */}
        {role && (
          <div class="flex items-center justify-between border-t border-(--color-border) pt-3">
            <dt class="text-(--color-text-muted)">Role</dt>
            <dd>{role}</dd>
          </div>
        )}

        {/* Timeframe */}
        {timeframe && (
          <div class="flex items-center justify-between border-t border-(--color-border) pt-3">
            <dt class="text-(--color-text-muted)">Timeframe</dt>
            <dd>{timeframe}</dd>
          </div>
        )}

        {/* Stack */}
        {stack.length > 0 && (
          <div class="border-t border-(--color-border) pt-3">
            <dt class="text-(--color-text-muted) mb-2">Stack</dt>
            <dd class="flex flex-wrap gap-1.5">
              {stack.map((tech) => (
                <span class="inline-block rounded-full border border-(--color-border) px-2.5 py-0.5 text-xs">
                  {tech}
                </span>
              ))}
            </dd>
          </div>
        )}
      </dl>

      {/* Links */}
      {links.length > 0 && (
        <div class="mt-4 pt-4 border-t border-(--color-border) flex flex-col gap-2">
          {links.map((link) => (
            <ButtonLink href={link.url} variant="secondary" external class="text-xs justify-center">
              {link.label}
            </ButtonLink>
          ))}
        </div>
      )}
    </div>
  )
}
