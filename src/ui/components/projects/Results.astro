---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <div class="mb-6" data-reveal>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-(--color-text-muted) mb-3">
        Results
      </h3>
      <ul class="space-y-2 text-sm border-l-2 border-(--color-accent) pl-4">
        {items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  )
}
