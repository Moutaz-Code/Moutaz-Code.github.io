---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <div class="mb-6" data-reveal>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-(--color-text-muted) mb-3">
        Highlights
      </h3>
      <ul class="space-y-2 text-sm">
        {items.map((item) => (
          <li class="flex gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-(--color-accent)" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  )
}
