---
// ThemeToggle — animated pill switch with sun/moon icons
---

<button
  id="theme-toggle"
  type="button"
  aria-pressed="false"
  aria-label="Toggle dark mode"
  class="theme-toggle"
>
  <span class="theme-toggle__track">
    <span class="theme-toggle__thumb" id="theme-thumb">
      <!-- Sun icon (light mode) -->
      <svg id="icon-sun" class="theme-toggle__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5" />
        <line x1="12" y1="1" x2="12" y2="3" />
        <line x1="12" y1="21" x2="12" y2="23" />
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
        <line x1="1" y1="12" x2="3" y2="12" />
        <line x1="21" y1="12" x2="23" y2="12" />
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
      </svg>
      <!-- Moon icon (dark mode) -->
      <svg id="icon-moon" class="theme-toggle__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
    </span>
  </span>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    border: none;
    background: none;
    padding: 2px;
    border-radius: 9999px;
    outline: none;
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .theme-toggle__track {
    display: flex;
    align-items: center;
    width: 44px;
    height: 24px;
    border-radius: 9999px;
    background-color: var(--color-border);
    padding: 2px;
    transition: background-color 0.2s ease;
  }

  .theme-toggle__thumb {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 9999px;
    background-color: var(--color-surface-raised);
    color: var(--color-text);
    /* transform handled by JS (Motion or CSS fallback) */
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .theme-toggle__icon {
    width: 12px;
    height: 12px;
    position: absolute;
    transition: opacity 0.2s ease, transform 0.3s ease;
  }

  /* Sun visible by default (light mode), moon hidden */
  #icon-sun { opacity: 1; transform: rotate(0deg); }
  #icon-moon { opacity: 0; transform: rotate(-90deg); }

  /* Dark mode: shift thumb right, swap icons */
  :global(html.theme-dark) #theme-thumb {
    transform: translateX(20px);
  }
  :global(html.theme-dark) .theme-toggle__track {
    background-color: var(--color-text-muted);
  }
  :global(html.theme-dark) #icon-sun {
    opacity: 0;
    transform: rotate(90deg);
  }
  :global(html.theme-dark) #icon-moon {
    opacity: 1;
    transform: rotate(0deg);
  }

  /* Reduced motion: minimal transitions */
  @media (prefers-reduced-motion: reduce) {
    .theme-toggle__thumb,
    .theme-toggle__icon,
    .theme-toggle__track {
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  import { toggleTheme } from "../../app/theme";

  const btn = document.getElementById("theme-toggle") as HTMLButtonElement;
  const isDark = document.documentElement.classList.contains("theme-dark");

  // Set initial aria state
  btn.setAttribute("aria-pressed", String(isDark));

  btn.addEventListener("click", () => {
    const next = toggleTheme();
    btn.setAttribute("aria-pressed", String(next === "dark"));
  });
</script>
