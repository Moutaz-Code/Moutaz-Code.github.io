---
interface Props {
  href?: string;
  class?: string;
  [key: string]: any;
}

const { href, class: className, ...rest } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  {...rest}
  class:list={[
    "block rounded-lg border border-(--color-border) p-4 sm:p-5 transition-colors",
    href && "no-underline text-(--color-text) hover:border-(--color-accent)",
    className,
  ]}
>
  <slot />
</Tag>
