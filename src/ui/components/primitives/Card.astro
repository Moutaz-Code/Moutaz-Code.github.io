---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "block rounded-lg border border-(--color-border) p-5 transition-colors",
    href && "no-underline text-(--color-text) hover:border-(--color-accent)",
    className,
  ]}
>
  <slot />
</Tag>
