---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  external?: boolean;
  class?: string;
  cursorLabel?: string;
  magnetic?: boolean;
  sfx?: "toggle" | "click";
}

const { href, variant = "secondary", external = false, class: className, cursorLabel, magnetic = false, sfx } = Astro.props;

const resolvedSfx = sfx ?? (variant === "primary" ? "click" : undefined);

const variantClasses = {
  primary:
    "bg-(--color-accent) text-(--color-accent-contrast) hover:bg-(--color-accent-hover)",
  secondary:
    "border border-(--color-border) text-(--color-text) hover:border-(--color-accent) hover:text-(--color-accent)",
  ghost:
    "text-(--color-text-muted) hover:text-(--color-text)",
} as const;
---

<a
  href={href}
  data-cursor="button"
  data-cursor-label={cursorLabel}
  data-magnetic={magnetic ? "" : undefined}
  data-sfx={resolvedSfx}
  class:list={[
    "inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium no-underline transition-colors",
    variantClasses[variant],
    className,
  ]}
  {...external ? { target: "_blank", rel: "noreferrer" } : {}}
>
  <slot />
</a>
