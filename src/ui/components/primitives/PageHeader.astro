---
import SignatureUnderline from "../signature/SignatureUnderline.astro";

interface Props {
  title: string;
  subtitle?: string;
  enableSignature?: boolean;
}

const { title, subtitle, enableSignature = false } = Astro.props;
---

<div class="mb-10" data-reveal>
  <h1 class="text-3xl font-bold tracking-tight">{title}</h1>
  {enableSignature && <SignatureUnderline variant="header" class="mt-1" />}
  {subtitle && <p class="mt-2 text-(--color-text-muted)">{subtitle}</p>}
  <slot name="actions" />
</div>
