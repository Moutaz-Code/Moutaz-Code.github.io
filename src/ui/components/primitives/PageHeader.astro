---
import SignatureUnderline from "../signature/SignatureUnderline.astro";

interface Props {
  title: string;
  subtitle?: string;
  enableSignature?: boolean;
}

const { title, subtitle, enableSignature = false } = Astro.props;
---

<div class="mb-8 sm:mb-10" data-reveal>
  <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">{title}</h1>
  {enableSignature && <SignatureUnderline variant="header" class="mt-1" />}
  {subtitle && <p class="mt-2 max-w-2xl text-sm sm:text-base text-(--color-text-muted)">{subtitle}</p>}
  <slot name="actions" />
</div>
