---
interface Props {
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { size = "lg", class: className } = Astro.props;

const maxWidths = {
  sm: "max-w-3xl",
  md: "max-w-5xl",
  lg: "max-w-6xl",
} as const;
---

<div class:list={["mx-auto w-full px-6", maxWidths[size], className]}>
  <slot />
</div>
