---
interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className } = Astro.props;
---

<section class:list={["py-10 sm:py-12", className]}>
  {
    title && (
      <div class="mb-6 sm:mb-8">
        <h2 class="text-xl sm:text-2xl font-bold tracking-tight">{title}</h2>
        {subtitle && (
          <p class="mt-1 max-w-2xl text-sm sm:text-base text-(--color-text-muted)">{subtitle}</p>
        )}
      </div>
    )
  }
  <slot />
</section>
