---
interface Props {
  currentPath: string;
  items: { label: string; href: string }[];
}

const { currentPath, items } = Astro.props;

function isActive(href: string, current: string): boolean {
  if (href === "/") return current === "/";
  return current.startsWith(href);
}
---

<nav class="flex min-w-0 flex-1 items-center gap-1 overflow-x-auto whitespace-nowrap text-sm [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
  {items.map((item) => (
    <a
      href={item.href}
      class:list={[
        "rounded-md px-2.5 py-1.5 no-underline transition-colors",
        isActive(item.href, currentPath)
          ? "text-(--color-text) font-medium bg-(--color-surface-raised) border border-(--color-border)"
          : "text-(--color-text-muted) hover:text-(--color-text)",
      ]}
      aria-current={isActive(item.href, currentPath) ? "page" : undefined}
    >
      {item.label}
    </a>
  ))}
</nav>
