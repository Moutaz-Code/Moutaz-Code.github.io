---
import TagChip from "./TagChip.astro";

interface Props {
  title: string;
  excerpt: string;
  slug: string;
  publishedAt?: string;
  tags: string[];
}

const { title, excerpt, slug, publishedAt, tags } = Astro.props;
---

<li>
  <a href={`/blog/${slug}`} class="block no-underline text-(--color-text) group">
    <p class="font-semibold group-hover:text-(--color-accent) transition-colors">
      {title}
    </p>
    <p class="text-sm text-(--color-text-muted) mt-0.5 mb-1">{excerpt}</p>
    <div class="flex items-center gap-3">
      {publishedAt && <span class="text-sm text-(--color-text-muted)">{publishedAt}</span>}
      <div class="flex gap-2">
        {tags.map((tag) => <TagChip tag={tag} />)}
      </div>
    </div>
  </a>
</li>
