---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="py-12">
  <div class="mb-8">
    <h2 class="text-2xl font-bold tracking-tight">{title}</h2>
    {subtitle && <p class="mt-1 text-(--color-text-muted)">{subtitle}</p>}
  </div>
  <slot />
</section>
