---
import FilterPills from "./FilterPills.astro";

interface Props {
  currentTag?: string;
  allTags: { slug: string; label: string }[];
}

const { currentTag, allTags } = Astro.props;

const pills = [
  { label: "All", href: "/blog", active: !currentTag },
  ...allTags.map((t) => ({
    label: t.label,
    href: `/blog?tag=${t.slug}`,
    active: currentTag === t.slug,
  })),
];
---

<div class="mb-8 space-y-4">
  <div class="flex items-start gap-3">
    <span
      class="text-xs font-medium text-(--color-text-muted) uppercase tracking-wide shrink-0 mt-1"
      >Topics</span
    >
    <FilterPills items={pills} />
  </div>

  {
    currentTag && (
      <a
        href="/blog"
        class="inline-block text-xs text-(--color-text-muted) hover:text-(--color-accent) no-underline"
      >
        Clear filter &times;
      </a>
    )
  }
</div>
