---
import FilterPills from "./FilterPills.astro";
import { buildUrl } from "../../../domain/rules/url";

interface Props {
  currentStatus?: string;
  currentTag?: string;
  allTags: { slug: string; label: string }[];
}

const { currentStatus, currentTag, allTags } = Astro.props;

const hasFilters = currentStatus != null || currentTag != null;

const statusPills = [
  {
    label: "All",
    href: buildUrl("/projects", { tag: currentTag }),
    active: !currentStatus,
  },
  {
    label: "Ongoing",
    href: buildUrl("/projects", { status: "ongoing", tag: currentTag }),
    active: currentStatus === "ongoing",
  },
  {
    label: "Completed",
    href: buildUrl("/projects", { status: "completed", tag: currentTag }),
    active: currentStatus === "completed",
  },
];

const tagPills = allTags.map((t) => ({
  label: t.label,
  href: buildUrl("/projects", { status: currentStatus, tag: t.slug }),
  active: currentTag === t.slug,
}));
---

<div class="mb-8 space-y-4">
  <div class="flex items-center gap-3">
    <span class="text-xs font-medium text-(--color-text-muted) uppercase tracking-wide shrink-0"
      >Status</span
    >
    <FilterPills items={statusPills} />
  </div>

  {
    tagPills.length > 0 && (
      <div class="flex items-start gap-3">
        <span class="text-xs font-medium text-(--color-text-muted) uppercase tracking-wide shrink-0 mt-1">
          Tags
        </span>
        <FilterPills items={tagPills} />
      </div>
    )
  }

  {
    hasFilters && (
      <a
        href="/projects"
        class="inline-block text-xs text-(--color-text-muted) hover:text-(--color-accent) no-underline"
      >
        Clear filters &times;
      </a>
    )
  }
</div>
