---
import TagChip from "./TagChip.astro";
import ResponsiveImage from "./ResponsiveImage.astro";

interface Props {
  title: string;
  slug: string;
  excerpt: string;
  tags: string[];
  publishedAt?: string;
  coverImage?: string;
  status?: "coming-soon";
}

const { title, slug, excerpt, publishedAt, tags, coverImage, status } = Astro.props;

const displayTags = tags.slice(0, 3);
const extraCount = tags.length - displayTags.length;
const isComingSoon = status === "coming-soon";
---

<li
  class:list={[
    "rounded-lg border border-(--color-border) p-5 transition-colors hover:border-(--color-accent) relative",
    isComingSoon && "opacity-70 pointer-events-none"
  ]}
  data-hover="lift"
  data-cursor="card"
>
  <a href={isComingSoon ? undefined : `/blog/${slug}`} class="block no-underline text-(--color-text) group">
    {coverImage && (
      <div class="aspect-video overflow-hidden rounded mb-3 relative">
        <ResponsiveImage
          src={coverImage}
          alt={title}
          variant="card"
          class="w-full h-full object-cover"
        />
        {isComingSoon && (
          <div class="absolute inset-0 bg-(--color-surface) bg-opacity-70 flex items-center justify-center">
            <span class="inline-block bg-yellow-200 text-yellow-900 text-xs font-bold px-3 py-1 rounded-full shadow">Coming Soon</span>
          </div>
        )}
      </div>
    )}
    <div class="flex items-center gap-2 mb-1">
      <p class="font-semibold group-hover:text-(--color-accent) transition-colors truncate">
        {title}
      </p>
      {isComingSoon && (
        <span class="inline-block bg-yellow-200 text-yellow-900 text-xs font-bold px-2 py-0.5 rounded-full">Coming Soon</span>
      )}
    </div>
    <p class="text-sm text-(--color-text-muted) mt-1 mb-2 line-clamp-2">
      {excerpt}
    </p>
    <div class="flex items-center gap-3 flex-wrap">
      {publishedAt && <time class="text-xs text-(--color-text-muted)">{publishedAt}</time>}
      <div class="flex gap-1.5">
        {displayTags.map((tag) => <TagChip tag={tag} interactive={false} />)}
        {extraCount > 0 && (
          <span class="text-xs text-(--color-text-muted) self-center">
            +{extraCount}
          </span>
        )}
      </div>
    </div>
  </a>
  {isComingSoon && (
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
      {/* Overlay for accessibility, already handled above for image, but ensures full card is covered */}
    </div>
  )}
</li>
