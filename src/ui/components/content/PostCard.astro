---
import TagChip from "./TagChip.astro";
import ResponsiveImage from "./ResponsiveImage.astro";

interface Props {
  title: string;
  slug: string;
  excerpt: string;
  tags: string[];
  publishedAt: string;
  coverImage?: string;
}

const { title, slug, excerpt, publishedAt, tags, coverImage } = Astro.props;

const displayTags = tags.slice(0, 3);
const extraCount = tags.length - displayTags.length;
---

<li
  class="rounded-lg border border-(--color-border) p-5 transition-colors hover:border-(--color-accent)"
  data-hover="lift"
>
  <a href={`/blog/${slug}`} class="block no-underline text-(--color-text) group">
    {
      coverImage && (
        <div class="aspect-video overflow-hidden rounded mb-3">
          <ResponsiveImage
            src={coverImage}
            alt={title}
            variant="card"
            class="w-full h-full object-cover"
          />
        </div>
      )
    }
    <p
      class="font-semibold group-hover:text-(--color-accent) transition-colors"
    >
      {title}
    </p>
    <p class="text-sm text-(--color-text-muted) mt-1 mb-2 line-clamp-2">
      {excerpt}
    </p>
    <div class="flex items-center gap-3 flex-wrap">
      <time class="text-xs text-(--color-text-muted)">{publishedAt}</time>
      <div class="flex gap-1.5">
        {displayTags.map((tag) => <TagChip tag={tag} interactive={false} />)}
        {
          extraCount > 0 && (
            <span class="text-xs text-(--color-text-muted) self-center">
              +{extraCount}
            </span>
          )
        }
      </div>
    </div>
  </a>
</li>
