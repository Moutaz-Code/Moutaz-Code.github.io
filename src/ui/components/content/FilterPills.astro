---
interface PillItem {
  label: string;
  href: string;
  active: boolean;
}

interface Props {
  items: PillItem[];
}

const { items } = Astro.props;
---

<div class="flex flex-wrap gap-2" data-filter-pills>
  {
    items.map((item) => (
      <a
        href={item.href}
        data-pill-href={item.href}
        {...(item.active ? { "data-pill-active": "" } : {})}
        class="filter-pill rounded-full px-3 py-1 text-xs font-medium no-underline transition-colors"
      >
        {item.label}
      </a>
    ))
  }
</div>

<style>
  .filter-pill {
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .filter-pill:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .filter-pill[data-pill-active] {
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
    border-color: var(--color-accent);
  }
  .filter-pill[data-pill-active]:hover {
    color: var(--color-accent-contrast);
  }
</style>
