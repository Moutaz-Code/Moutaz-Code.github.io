---
import Card from "../primitives/Card.astro";
import TagChip from "./TagChip.astro";
import StatusBadge from "./StatusBadge.astro";
import ResponsiveImage from "./ResponsiveImage.astro";

interface Props {
  title: string;
  slug: string;
  summary: string;
  tags: string[];
  status: "ongoing" | "completed" | "coming-soon";
  featured: boolean;
  primaryImage?: { src: string; alt?: string };
}

const { title, slug, summary, tags, status, featured, primaryImage } = Astro.props;

const displayTags = tags.slice(0, 3);
const extraCount = tags.length - displayTags.length;
const isComingSoon = status === "coming-soon";
---

<Card
  href={isComingSoon ? undefined : `/projects/${slug}`}
  class={[featured ? "border-(--color-accent)/30" : "", isComingSoon ? "opacity-70 pointer-events-none relative" : ""]}
  data-hover="lift"
  data-cursor="card"
  data-project-slug={slug}
>
  {primaryImage && (
    <div class="aspect-video overflow-hidden rounded mb-3 relative">
      <ResponsiveImage
        src={primaryImage.src}
        alt={primaryImage.alt ?? title}
        variant="card"
        class="w-full h-full object-cover"
      />
      {isComingSoon && (
        <div class="absolute inset-0 bg-(--color-surface) bg-opacity-70 flex items-center justify-center">
          <span class="inline-block bg-yellow-200 text-yellow-900 text-xs font-bold px-3 py-1 rounded-full shadow">Coming Soon</span>
        </div>
      )}
    </div>
  )}
  <div class="flex items-center justify-between gap-2 mb-2">
    <h3 class="font-semibold truncate">{title}</h3>
    {isComingSoon ? (
      <span class="inline-block bg-yellow-200 text-yellow-900 text-xs font-bold px-2 py-0.5 rounded-full">Coming Soon</span>
    ) : (
      <StatusBadge status={status} />
    )}
  </div>
  <p class="text-sm text-(--color-text-muted) mb-3 line-clamp-2">{summary}</p>
  <div class="flex gap-1.5 flex-wrap">
    {displayTags.map((tag) => <TagChip tag={tag} interactive={false} />)}
    {extraCount > 0 && (
      <span class="text-xs text-(--color-text-muted) self-center">+{extraCount}</span>
    )}
  </div>
  {isComingSoon && (
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
      {/* Overlay for accessibility, already handled above for image, but ensures full card is covered */}
    </div>
  )}
</Card>
