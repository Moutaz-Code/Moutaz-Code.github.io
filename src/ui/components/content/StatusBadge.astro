---
interface Props {
  status: "ongoing" | "completed";
}

const { status } = Astro.props;
---

<span
  class:list={[
    "inline-block text-xs px-2 py-0.5 rounded-full font-medium",
    status === "ongoing"
      ? "bg-green-100 text-green-700"
      : "bg-gray-100 text-(--color-text-muted)",
  ]}
>
  {status}
</span>
