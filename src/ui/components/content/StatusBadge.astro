---
interface Props {
  status: "ongoing" | "completed";
}

const { status } = Astro.props;
---

<span
  class:list={[
    "inline-block text-xs px-2 py-0.5 rounded-full font-medium",
    status === "ongoing"
      ? "bg-(--color-status-ongoing-bg) text-(--color-status-ongoing-text)"
      : "bg-(--color-status-completed-bg) text-(--color-text-muted)",
  ]}
>
  {status}
</span>
