---
// AmbientInit — animates the ambient layer (pointer tracking, blob drift, parallax).
// Include once after AmbientLayer to start the animation loop.
// RAF pauses when the tab is hidden. scrollY is cached via passive listener.
---

<script>
  import { prefersReducedMotion } from "../../runtime/prefs";

  const isTouch =
    typeof window !== "undefined" &&
    ("ontouchstart" in window || navigator.maxTouchPoints > 0);

  if (!prefersReducedMotion()) {
    // ── Pointer state ──────────────────────────────────
    let pointerX = 0; // normalised -1 … 1
    let pointerY = 0;
    let smoothX = 0;
    let smoothY = 0;
    const LERP = 0.04;

    if (!isTouch) {
      document.addEventListener("mousemove", (e) => {
        pointerX = (e.clientX / window.innerWidth) * 2 - 1;
        pointerY = (e.clientY / window.innerHeight) * 2 - 1;
      });
    }

    // ── Elements ───────────────────────────────────────
    const blobs = document.querySelectorAll<HTMLElement>(".ambient-blob");
    const shapes = document.querySelectorAll<HTMLElement>(".ambient-shape");

    // Drift config per blob (period in seconds, amplitude in px)
    const drift = [
      { px: 30, py: 20, tx: 12, ty: 15 },
      { px: 25, py: 35, tx: 16, ty: 10 },
      { px: 20, py: 25, tx: 10, ty: 18 },
      { px: 28, py: 22, tx: 14, ty: 12 },
      { px: 22, py: 30, tx: 11, ty: 16 },
    ];

    // ── Cached scroll position (passive listener) ─────
    let cachedScrollY = window.scrollY;
    window.addEventListener("scroll", () => { cachedScrollY = window.scrollY; }, { passive: true });

    // ── RAF management ────────────────────────────────
    let rafId: number | null = null;
    let running = false;

    function startLoop() {
      if (!running) {
        running = true;
        rafId = requestAnimationFrame(tick);
      }
    }

    function stopLoop() {
      if (running) {
        running = false;
        if (rafId !== null) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
      }
    }

    // ── Visibility pause ──────────────────────────────
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        stopLoop();
      } else {
        startLoop();
      }
    });

    // ── Animation loop ─────────────────────────────────
    let start = 0;
    function tick(now: number) {
      if (!start) start = now;
      const t = (now - start) / 1000; // seconds

      // Smooth pointer
      smoothX += (pointerX - smoothX) * LERP;
      smoothY += (pointerY - smoothY) * LERP;

      // Animate blobs: slow sine drift + pointer influence
      blobs.forEach((blob, i) => {
        const d = drift[i] ?? drift[0];
        const dx =
          Math.sin(t / d.tx) * d.px + smoothX * 30; // max 30px pointer drift
        const dy =
          Math.sin(t / d.ty + 1) * d.py + smoothY * 20; // max 20px pointer drift
        blob.style.transform = `translate(${dx}px, ${dy}px)`;
      });

      // Parallax shapes: scroll + pointer offset
      shapes.forEach((shape) => {
        const depth = parseFloat(
          shape.getAttribute("data-parallax-depth") ?? "0.02",
        );
        const sx = smoothX * 40 * depth * 10; // subtle pointer parallax
        const sy = -cachedScrollY * depth + smoothY * 30 * depth * 10;
        shape.style.transform = `translate(${sx}px, ${sy}px)`;
      });

      rafId = requestAnimationFrame(tick);
    }

    startLoop();
  }
</script>
