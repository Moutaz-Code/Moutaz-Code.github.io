---
// AmbientLayer — decorative background with gradient blobs, parallax shapes, and grain overlay.
// Pass variant="a" | "b" | "c" for per-page visual variation.
import "../../../styles/ambient.css";

interface Props {
  variant?: "a" | "b" | "c";
}

const { variant = "a" } = Astro.props;

// Each variant uses a different mix of blobs and shapes
const variantConfig = {
  a: { blobs: [1, 2, 3], shapes: [1, 2, 3] },
  b: { blobs: [1, 3, 4], shapes: [2, 4, 5] },
  c: { blobs: [2, 4, 5], shapes: [1, 3, 5] },
} as const;

const { blobs, shapes } = variantConfig[variant];
const depths = [0.02, 0.035, 0.015];
---

<div class="ambient-root" id="ambient-root" data-variant={variant} aria-hidden="true">
  <!-- Gradient blobs -->
  {blobs.map((id) => <div class="ambient-blob" data-blob={String(id)} />)}

  <!-- Parallax shapes -->
  {shapes.map((id, i) => (
    <div class="ambient-shape" data-shape={String(id)} data-parallax-depth={String(depths[i])} />
  ))}

  <!-- Grain overlay -->
  <div class="ambient-grain"></div>
</div>
