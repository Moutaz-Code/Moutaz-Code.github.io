---
interface Props {
  shaderId: string;
  title?: string;
}

const { shaderId, title = "ShaderToy shader" } = Astro.props;
const embedUrl = `https://www.shadertoy.com/embed/${shaderId}?gui=false&t=10&paused=false&muted=true`;
---

<div class="rounded-lg border border-(--color-border) p-5 mb-8" data-reveal>
  <div class="flex items-center gap-2 mb-3">
    {/* Shader / sparkle icon */}
    <svg class="w-5 h-5 text-(--color-text-muted) shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
    </svg>
    <span class="font-semibold text-sm">ShaderToy Demo</span>
  </div>

  <div class="relative w-full" style="aspect-ratio: 16 / 9;">
    <iframe
      src={embedUrl}
      title={title}
      frameborder="0"
      loading="lazy"
      allowfullscreen
      class="absolute inset-0 w-full h-full border-0 rounded"
    ></iframe>
  </div>
</div>
