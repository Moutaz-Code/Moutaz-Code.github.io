---
// SignatureUnderline — reusable SVG stroke underline with optional bloom.
// Animation handled by signature.ts (anime.js, lazy-loaded).
// Without JS or with reduced motion, the stroke is fully visible.
import "../../../styles/anime-signature.css";

interface Props {
  variant?: "header" | "detail";
  class?: string;
}

const { variant = "header", class: className } = Astro.props;

const isHeader = variant === "header";
const width = isHeader ? 160 : 120;
const height = 12;
const path = isHeader
  ? "M2 8 C 30 2, 70 2, 100 7 S 140 10, 158 5"
  : "M2 7 C 25 2, 55 3, 80 7 S 105 9, 118 5";
---

<div class:list={["relative", className]} data-signature-root>
  <svg
    class="hero-signature-svg"
    data-signature-svg
    width={width}
    height={height}
    viewBox={`0 0 ${width} ${height}`}
    aria-hidden="true"
  >
    <path
      class="hero-signature-path"
      data-signature-path
      d={path}
    />
  </svg>
</div>
