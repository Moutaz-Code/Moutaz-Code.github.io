---
// CornerSpark — tiny decorative dots that fade/drift near the corner flourish.
// Animation handled by signature.ts (anime.js). Hidden by default (no-JS safe).
import "../../../styles/anime-signature.css";

interface Props {
  position?: "top-right" | "top-left";
  class?: string;
}

const { position = "top-right", class: className } = Astro.props;

const isRight = position === "top-right";
const dots = [0, 1, 2, 3];
---

<div
  class:list={[
    "absolute pointer-events-none",
    isRight ? "top-0 right-0" : "top-0 left-0",
    className,
  ]}
  data-corner-spark
  aria-hidden="true"
>
  {dots.map((i) => (
    <div
      class="corner-spark-dot"
      data-spark-dot
      data-spark-index={String(i)}
    />
  ))}
</div>
