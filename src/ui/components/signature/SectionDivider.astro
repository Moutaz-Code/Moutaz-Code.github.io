---
// SectionDivider — subtle SVG divider between major page sections.
// Animates with stroke draw-on-scroll (via DividerInit). Visible by default (no-JS safe).
import "../../../styles/anime-signature.css";

interface Props {
  variant?: "wave" | "circuit" | "harmonic";
  class?: string;
}

const { variant = "wave", class: className } = Astro.props;

// Wave: gentle organic curve spanning full width
const wavePath =
  "M0 16 C 80 4, 160 28, 240 14 S 400 4, 480 18 S 640 28, 720 12 S 880 4, 960 16";

// Circuit: miniature digital signal — small square pulses along the center
const circuitPath = [
  "M0 18",
  "L80 18",       // flat lead-in
  "L80 10 L120 10 L120 18",   // pulse 1 (up)
  "L180 18",
  "L180 10 L210 10 L210 18",  // pulse 2 (up, narrower)
  "L300 18",
  "L300 22 L340 22 L340 18",  // pulse 3 (down)
  "L420 18",
  "L420 10 L470 10 L470 18",  // pulse 4 (up, wider)
  "L540 18",
  "L540 22 L565 22 L565 18",  // pulse 5 (down, narrow)
  "L650 18",
  "L650 10 L685 10 L685 18",  // pulse 6 (up)
  "L760 18",
  "L760 22 L790 22 L790 18",  // pulse 7 (down)
  "L870 18",
  "L870 10 L900 10 L900 18",  // pulse 8 (up)
  "L960 18",      // flat tail
].join(" ");

// Harmonic: dense composite sine wave — many overlapping frequencies
// with prime-based ratios produce a complex, non-repeating waveform.
function buildHarmonicPath(): string {
  const steps = 960;
  const amp = 30;
  const parts: string[] = [];

  // Harmonic series: [frequency multiplier, amplitude, phase offset]
  const harmonics: [number, number, number][] = [
    [2,   1.00,  0.0],
    [3,   0.72,  0.8],
    [5,   0.48,  1.4],
    [7,   0.33,  0.3],
    [9,   0.26,  2.5],
    [11,  0.20,  2.1],
    [13,  0.16,  0.7],
    [15,  0.13,  3.2],
    [17,  0.10,  1.9],
    [19,  0.08,  0.4],
    [23,  0.065, 0.5],
    [29,  0.05,  1.7],
    [31,  0.04,  2.9],
    [37,  0.032, 0.9],
    [41,  0.025, 3.5],
    [43,  0.020, 1.2],
    [47,  0.016, 2.3],
    [53,  0.012, 0.6],
    [59,  0.010, 3.8],
  ];

  const norm = harmonics.reduce((sum, [, a]) => sum + a, 0);

  for (let i = 0; i <= steps; i++) {
    const t = (i / steps) * Math.PI * 2;
    let raw = 0;
    for (const [freq, amplitude, phase] of harmonics) {
      raw += Math.sin(t * freq + phase) * amplitude;
    }
    const x = Math.round(((i / steps) * 960) * 100) / 100;
    const y = Math.round((16 + (raw / norm) * amp) * 100) / 100;
    parts.push(i === 0 ? `M${x} ${y}` : `L${x} ${y}`);
  }
  return parts.join(" ");
}
const harmonicPath = buildHarmonicPath();

const paths: Record<string, string> = {
  wave: wavePath,
  circuit: circuitPath,
  harmonic: harmonicPath,
};
const path = paths[variant];
---

<div
  class:list={["section-divider", className]}
  data-divider-root
  aria-hidden="true"
>
  <svg
    class="section-divider-svg"
    data-divider-svg
    viewBox="0 0 960 32"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path
      class="section-divider-path"
      data-divider-path
      d={path}
    />
  </svg>
</div>
