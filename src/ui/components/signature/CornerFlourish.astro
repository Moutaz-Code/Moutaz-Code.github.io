---
// CornerFlourish — small decorative SVG corner bracket for detail page headers.
// Animation handled by signature.ts (anime.js, lazy-loaded).
// Without JS or with reduced motion, the corner is fully visible.
import "../../../styles/anime-signature.css";

interface Props {
  position?: "top-right" | "top-left";
  class?: string;
}

const { position = "top-right", class: className } = Astro.props;

const isRight = position === "top-right";

// Rounded corner bracket path (L-shape with curve)
const path = isRight
  ? "M2 2 L26 2 C29 2, 30 3, 30 6 L30 30"
  : "M2 30 L2 6 C2 3, 3 2, 6 2 L30 2";
---

<div
  class:list={[
    "absolute pointer-events-none",
    isRight ? "top-0 right-0" : "top-0 left-0",
    className,
  ]}
  data-signature-root
  data-signature-corner
>
  <svg
    class="hero-signature-svg"
    data-signature-svg
    width="32"
    height="32"
    viewBox="0 0 32 32"
    aria-hidden="true"
  >
    <path
      class="hero-signature-path corner-flourish-path"
      data-signature-path
      d={path}
    />
  </svg>
</div>
