---
// PageTransitionInit — fade-out on internal link click, fade-in on page load.
// Respects reduced motion. Skips external, hash, _blank, and /admin links.
// CSS lives in src/styles/transitions.css (imported via global.css).
---

<script>
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reduced) {
    const html = document.documentElement;

    // ── Clean up fade-in (class was added by inline head script) ──
    const onEnterDone = () => {
      html.classList.remove("is-entering");
    };
    document.body.addEventListener("animationend", onEnterDone, { once: true });
    setTimeout(onEnterDone, 350); // safety fallback

    // ── Fade out on internal link click ────────────────
    document.addEventListener("click", (e) => {
      const anchor = (e.target as HTMLElement).closest("a");
      if (!anchor) return;

      const href = anchor.getAttribute("href");
      if (!href) return;

      // Skip: modifier keys (new tab intent)
      if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;

      // Skip: explicitly opens in new tab
      if (anchor.target === "_blank") return;

      // Skip: hash-only links
      if (href.startsWith("#")) return;

      // Skip: external links
      try {
        const url = new URL(href, window.location.origin);
        if (url.origin !== window.location.origin) return;

        // Skip: admin routes
        if (url.pathname.startsWith("/admin")) return;

        // Skip: same page (hash navigation on current page)
        if (url.pathname === window.location.pathname && url.hash) return;
      } catch {
        return;
      }

      // Prevent default navigation
      e.preventDefault();

      // Apply fade-out
      html.classList.remove("is-entering");
      html.classList.add("is-leaving");

      // Navigate after fade-out completes
      setTimeout(() => {
        window.location.href = href;
      }, 180);
    });

    // ── Handle back/forward (bfcache) ─────────────────
    window.addEventListener("pageshow", (e) => {
      if (e.persisted) {
        // Page restored from bfcache — reset state
        html.classList.remove("is-leaving");
        html.classList.add("is-entering");
        setTimeout(() => html.classList.remove("is-entering"), 350);
      }
    });
  }
</script>
