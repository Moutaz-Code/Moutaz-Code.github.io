---
// SoundInit — listens for clicks on [data-sfx] elements and plays the
// corresponding micro-sound. Include once at the bottom of BaseLayout.
---

<script>
  import { play } from "../../app/sound";

  document.addEventListener("click", (e) => {
    const target = (e.target as Element).closest<HTMLElement>("[data-sfx]");
    if (!target) return;
    const sfx = target.dataset.sfx;
    if (sfx === "toggle" || sfx === "click") {
      play(sfx);
    }
  });
</script>
